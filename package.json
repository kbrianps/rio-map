{
  "name": "@kbrianps/rio-map",
  "version": "0.2.1",
  "description": "Mapa minimalista do município do Rio de Janeiro com tiles CartoCDN. Zero deps, ~10 KB gzip.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:baseline": "node scripts/build-baseline.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "sharp": "^0.34.5",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/kbrianps/rio-map.git"
  },
  "keywords": [
    "rio",
    "rio-de-janeiro",
    "map",
    "leaflet-alternative",
    "canvas",
    "minimal"
  ]
}
